{
  "$id": "https://assay.dev/schemas/merge-execute-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MergeExecuteResult",
  "description": "Result of executing `git merge --no-ff`.\n\nOn success, contains the merge commit SHA and changed files.\nOn conflict, contains conflict details with automatic abort cleanup.",
  "type": "object",
  "properties": {
    "conflict_details": {
      "description": "Conflict details when `was_conflict` is true.",
      "anyOf": [
        {
          "$ref": "#/$defs/ConflictScan"
        },
        {
          "type": "null"
        }
      ]
    },
    "files_changed": {
      "description": "Files changed by the merge (present only on success).",
      "type": "array",
      "items": {
        "$ref": "#/$defs/FileChange"
      }
    },
    "merge_sha": {
      "description": "SHA of the merge commit (present only on success).",
      "type": [
        "string",
        "null"
      ]
    },
    "was_conflict": {
      "description": "Whether the merge had a conflict.",
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "required": [
    "was_conflict"
  ],
  "$defs": {
    "ChangeType": {
      "description": "Change type for files in a clean merge.",
      "oneOf": [
        {
          "description": "File was added.",
          "type": "string",
          "const": "added"
        },
        {
          "description": "File was modified.",
          "type": "string",
          "const": "modified"
        },
        {
          "description": "File was deleted.",
          "type": "string",
          "const": "deleted"
        }
      ]
    },
    "ConflictMarker": {
      "description": "A single conflict marker found in a file.",
      "type": "object",
      "properties": {
        "file": {
          "description": "File path relative to the repository root.",
          "type": "string"
        },
        "line": {
          "description": "1-based line number where the marker was found.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "marker_type": {
          "description": "Type of marker (`<<<<<<<`, `=======`, or `>>>>>>>`).",
          "$ref": "#/$defs/MarkerType"
        }
      },
      "additionalProperties": false,
      "required": [
        "file",
        "line",
        "marker_type"
      ]
    },
    "ConflictScan": {
      "description": "Result of scanning files for conflict markers.",
      "type": "object",
      "properties": {
        "has_markers": {
          "description": "Whether any conflict markers were found.",
          "type": "boolean"
        },
        "markers": {
          "description": "Individual markers found (may be empty).",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ConflictMarker"
          }
        },
        "truncated": {
          "description": "Whether the scan was truncated (too many files or markers).",
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "has_markers",
        "truncated"
      ]
    },
    "FileChange": {
      "description": "A file changed in a clean merge.",
      "type": "object",
      "properties": {
        "change_type": {
          "description": "Type of change (added, modified, or deleted).",
          "$ref": "#/$defs/ChangeType"
        },
        "path": {
          "description": "Path of the changed file relative to the repository root.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "path",
        "change_type"
      ]
    },
    "MarkerType": {
      "description": "Type of a conflict marker found in a file.",
      "oneOf": [
        {
          "description": "Start of \"ours\" side: `<<<<<<<`",
          "type": "string",
          "const": "ours"
        },
        {
          "description": "Separator between sides: `=======`",
          "type": "string",
          "const": "separator"
        },
        {
          "description": "Start of \"theirs\" side: `>>>>>>>`",
          "type": "string",
          "const": "theirs"
        }
      ]
    }
  }
}
