{
  "$id": "https://assay.dev/schemas/config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Top-level configuration for an Assay project.\n\nLoaded from `.assay/config.toml`.",
  "type": "object",
  "properties": {
    "gates": {
      "description": "Gate execution configuration.",
      "anyOf": [
        {
          "$ref": "#/$defs/GatesConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "project_name": {
      "description": "Project name (required, non-empty after trim).",
      "type": "string"
    },
    "specs_dir": {
      "description": "Directory containing spec files, relative to `.assay/`.\nDefaults to `\"specs/\"`.",
      "type": "string",
      "default": "specs/"
    }
  },
  "additionalProperties": false,
  "required": [
    "project_name"
  ],
  "$defs": {
    "GatesConfig": {
      "description": "Gate execution configuration.",
      "type": "object",
      "properties": {
        "default_timeout": {
          "description": "Default timeout for gate commands in seconds. Defaults to 300.",
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        },
        "working_dir": {
          "description": "Working directory for gate execution.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
