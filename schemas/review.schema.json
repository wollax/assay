{
  "$id": "https://assay.dev/schemas/review.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review",
  "description": "A review of completed work against a spec.",
  "type": "object",
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "spec_name": {
      "type": "string"
    }
  },
  "required": [
    "spec_name",
    "approved"
  ]
}
