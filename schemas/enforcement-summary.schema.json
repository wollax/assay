{
  "$id": "https://assay.dev/schemas/enforcement-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnforcementSummary",
  "description": "Enforcement breakdown in a gate run summary.\n\nAlways present on `GateRunSummary`, with counts defaulting to 0.\nOnly counts executable criteria (skipped criteria are excluded).",
  "type": "object",
  "properties": {
    "advisory_failed": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "advisory_passed": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "required_failed": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "required_passed": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    }
  },
  "required": [
    "required_passed",
    "required_failed",
    "advisory_passed",
    "advisory_failed"
  ]
}
