#!/usr/bin/env bash
set -euo pipefail

# Parse the remote and ref being pushed to detect protected branches
remote="$1"
url="$2"

protected_branches="main release/*"

while read local_ref local_oid remote_ref remote_oid; do
    # Extract branch name from refs/heads/...
    branch="${remote_ref#refs/heads/}"

    for pattern in $protected_branches; do
        # shellcheck disable=SC2254
        case "$branch" in
            $pattern)
                echo "🛡️  pre-push: pushing to protected branch '$branch' — running full checks..."

                echo "🔨 Building workspace..."
                if ! cargo build --workspace --all-targets; then
                    echo ""
                    echo "❌ Build failed. Fix errors before pushing to '$branch'."
                    exit 1
                fi

                echo "🧪 Running tests..."
                if ! cargo test --workspace; then
                    echo ""
                    echo "❌ Tests failed. Fix them before pushing to '$branch'."
                    exit 1
                fi

                echo "✅ pre-push: all checks passed for protected branch '$branch'."
                # Only need to run the full suite once per push
                exit 0
                ;;
        esac
    done
done

echo "✅ pre-push: non-protected branch, skipping full build/test."
