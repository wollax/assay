name: CI

on:
  push:
    branches: [main]
  pull_request:

env:
  CARGO_TERM_COLOR: always

jobs:
  check:
    name: Check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      - uses: Swatinem/rust-cache@v2
      - uses: jdx/mise-action@v2
      - run: just ready

  plugins:
    name: Validate plugins
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Validate Claude Code plugin.json
        run: python3 -c "import json; json.load(open('plugins/claude-code/.claude-plugin/plugin.json'))"
      - name: Validate OpenCode opencode.json
        run: python3 -c "import json; json.load(open('plugins/opencode/opencode.json'))"
      - name: Validate OpenCode package.json
        run: python3 -c "import json; json.load(open('plugins/opencode/package.json'))"
      - name: Validate OpenCode tsconfig.json
        run: python3 -c "import json; json.load(open('plugins/opencode/tsconfig.json'))"
