---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$defs": {
    "Gate": {
      "description": "A quality gate that must pass before work proceeds.",
      "properties": {
        "name": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "passed"
      ],
      "type": "object"
    },
    "Spec": {
      "description": "A specification that defines what should be built and its acceptance criteria.",
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "type": "object"
    },
    "Workflow": {
      "description": "A workflow combining specs, gates, and reviews into a development pipeline.",
      "properties": {
        "gates": {
          "items": {
            "$ref": "#/$defs/Gate"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "specs": {
          "items": {
            "$ref": "#/$defs/Spec"
          },
          "type": "array"
        }
      },
      "required": [
        "name",
        "specs",
        "gates"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Top-level configuration for Assay.",
  "properties": {
    "project_name": {
      "type": "string"
    },
    "workflows": {
      "items": {
        "$ref": "#/$defs/Workflow"
      },
      "type": "array"
    }
  },
  "required": [
    "project_name",
    "workflows"
  ],
  "title": "Config",
  "type": "object"
}
