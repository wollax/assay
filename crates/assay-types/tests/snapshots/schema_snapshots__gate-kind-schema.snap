---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The kind of gate to evaluate.\n\nUses internal tagging (`#[serde(tag = \"kind\")]`) so TOML output includes\na `kind = \"Command\"` or `kind = \"AlwaysPass\"` discriminator field.",
  "oneOf": [
    {
      "description": "A gate that runs a shell command and checks its exit code.",
      "properties": {
        "cmd": {
          "description": "The shell command to execute.",
          "type": "string"
        },
        "kind": {
          "const": "Command",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "cmd"
      ],
      "type": "object"
    },
    {
      "description": "A gate that always passes — useful for placeholder or manual gates.",
      "properties": {
        "kind": {
          "const": "AlwaysPass",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    {
      "description": "A gate that checks whether a file exists at the given path.",
      "properties": {
        "kind": {
          "const": "FileExists",
          "type": "string"
        },
        "path": {
          "description": "Path to check, relative to the working directory.",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "path"
      ],
      "type": "object"
    },
    {
      "description": "A gate evaluated by an agent via structured reasoning.",
      "properties": {
        "kind": {
          "const": "AgentReport",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    {
      "description": "A gate that counts events of a specific type in the agent session log.\n\n`event_type` must match the serde tag of an `AgentEvent` variant:\n`\"tool_called\"`, `\"tool_result\"`, `\"turn_ended\"`, `\"session_stopped\"`,\n`\"text_delta\"`, `\"text_block\"`.\n\nPasses when `count >= min.unwrap_or(0) && count <= max.unwrap_or(u32::MAX)`.",
      "properties": {
        "event_type": {
          "description": "The event type to count, matching an `AgentEvent` serde tag.",
          "type": "string"
        },
        "kind": {
          "const": "EventCount",
          "type": "string"
        },
        "max": {
          "description": "Inclusive upper bound on the matched event count. `None` means no upper bound.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "min": {
          "description": "Inclusive lower bound on the matched event count. `None` means no lower bound.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "event_type"
      ],
      "type": "object"
    },
    {
      "description": "A gate that passes only when no tool invocation in the session returned an error.\n\nFails if any `AgentEvent::ToolResult { is_error: true, .. }` is present.",
      "properties": {
        "kind": {
          "const": "NoToolErrors",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    }
  ],
  "title": "GateKind"
}
