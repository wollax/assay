---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A reference to a `GatesSpec` chunk within a milestone, identified by slug and ordering.\n\nEach `ChunkRef` corresponds to a directory-based spec (a \"chunk\") that\ncontributes to the parent milestone. The `order` field controls the\ncanonical sequence for display and progress tracking.",
  "properties": {
    "order": {
      "description": "Position of this chunk in the milestone's ordered sequence (0-based or 1-based is caller's choice).",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "slug": {
      "description": "Slug of the referenced `GatesSpec` (matches the spec directory/file name).",
      "type": "string"
    }
  },
  "required": [
    "slug",
    "order"
  ],
  "title": "ChunkRef",
  "type": "object"
}
