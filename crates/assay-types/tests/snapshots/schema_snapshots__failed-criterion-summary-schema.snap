---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Summary of a single failed gate criterion for diagnostic persistence.",
  "properties": {
    "command": {
      "description": "The command that was executed (if any).",
      "type": [
        "string",
        "null"
      ]
    },
    "criterion_name": {
      "description": "Name of the criterion that failed.",
      "type": "string"
    },
    "exit_code": {
      "description": "Exit code from the command (if applicable).",
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "stderr_snippet": {
      "default": "",
      "description": "Stderr snippet from the failed command (truncated).",
      "type": "string"
    }
  },
  "required": [
    "criterion_name"
  ],
  "title": "FailedCriterionSummary",
  "type": "object"
}
