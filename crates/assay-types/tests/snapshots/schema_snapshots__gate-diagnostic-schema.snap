---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$defs": {
    "FailedCriterionSummary": {
      "additionalProperties": false,
      "description": "Summary of a single failed gate criterion for diagnostic persistence.",
      "properties": {
        "command": {
          "description": "The command that was executed (if any).",
          "type": [
            "string",
            "null"
          ]
        },
        "criterion_name": {
          "description": "Name of the criterion that failed.",
          "type": "string"
        },
        "exit_code": {
          "description": "Exit code from the command (if applicable).",
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "stderr_snippet": {
          "default": "",
          "description": "Stderr snippet from the failed command (truncated).",
          "type": "string"
        }
      },
      "required": [
        "criterion_name"
      ],
      "type": "object"
    },
    "SessionPhase": {
      "description": "The phase in a pipeline session at which a checkpoint gate was evaluated.\n\nLives in `review` (not `gate` or `pipeline`) per D029 — phase is a\ndiagnostic concern that belongs next to [`GateDiagnostic`].\n\nAccessed as `assay_types::review::SessionPhase` — deliberately NOT\nre-exported at the crate root to avoid collision with the workflow\n`SessionPhase` in `work_session`.",
      "oneOf": [
        {
          "description": "Gate was evaluated at a tool-call checkpoint (`n` = tool call count).",
          "properties": {
            "n": {
              "description": "Number of tool calls emitted when the checkpoint fired.",
              "format": "uint32",
              "minimum": 0,
              "type": "integer"
            },
            "type": {
              "const": "at_tool_call",
              "type": "string"
            }
          },
          "required": [
            "type",
            "n"
          ],
          "type": "object"
        },
        {
          "description": "Gate was evaluated when a specific event type was observed.",
          "properties": {
            "event_type": {
              "description": "The event type tag that triggered the checkpoint.",
              "type": "string"
            },
            "type": {
              "const": "at_event",
              "type": "string"
            }
          },
          "required": [
            "type",
            "event_type"
          ],
          "type": "object"
        },
        {
          "description": "Gate was evaluated at the end of the session.",
          "properties": {
            "type": {
              "const": "session_end",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Persistent record of gate failures from a pipeline run.\n\nWritten to `.assay/reviews/<spec>/<run-id>-gates.json` when a run\ncompletes with gate failures. Read by `assay spec review` to show\nfailure details alongside structural checks.\n\n# Security note\n\nDiagnostic files may contain output captured from gate commands (see\n[`FailedCriterionSummary::stderr_snippet`]). Gate commands are arbitrary\nshell commands, so their output could theoretically include sensitive data\n(API keys, tokens, passwords) if a failing command printed them to stderr.\nTreat `.assay/reviews/` with the same access controls as `.assay/sessions/`.",
  "properties": {
    "checkpoint_index": {
      "description": "Index of the checkpoint that failed (0-based). `None` for session-end gates.",
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "failed": {
      "description": "Number of criteria that failed.",
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "failed_criteria": {
      "description": "Details of each failed criterion.",
      "items": {
        "$ref": "#/$defs/FailedCriterionSummary"
      },
      "type": "array"
    },
    "passed": {
      "description": "Number of criteria that passed.",
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "run_id": {
      "description": "Run identifier (matches the session's run_id).",
      "type": "string"
    },
    "session_phase": {
      "$ref": "#/$defs/SessionPhase",
      "default": {
        "type": "session_end"
      },
      "description": "The pipeline phase at which the gate was evaluated.\nDefaults to `SessionEnd` for pre-M024 diagnostics (D028)."
    },
    "spec": {
      "description": "Spec slug this diagnostic is for.",
      "type": "string"
    },
    "timestamp": {
      "description": "When the gate evaluation completed.",
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "spec",
    "run_id",
    "timestamp",
    "failed_criteria",
    "passed",
    "failed"
  ],
  "title": "GateDiagnostic",
  "type": "object"
}
