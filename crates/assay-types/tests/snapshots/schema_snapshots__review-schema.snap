---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A review of completed work against a spec.",
  "properties": {
    "approved": {
      "description": "Whether the review approved the work.",
      "type": "boolean"
    },
    "comments": {
      "description": "Reviewer comments. Omitted from serialized output when empty.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "spec_name": {
      "description": "Name of the spec that was reviewed.",
      "type": "string"
    }
  },
  "required": [
    "spec_name",
    "approved"
  ],
  "title": "Review",
  "type": "object"
}
