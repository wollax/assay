---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The phase in a pipeline session at which a checkpoint gate was evaluated.\n\nLives in `review` (not `gate` or `pipeline`) per D029 — phase is a\ndiagnostic concern that belongs next to [`GateDiagnostic`].\n\nAccessed as `assay_types::review::SessionPhase` — deliberately NOT\nre-exported at the crate root to avoid collision with the workflow\n`SessionPhase` in `work_session`.",
  "oneOf": [
    {
      "description": "Gate was evaluated at a tool-call checkpoint (`n` = tool call count).",
      "properties": {
        "n": {
          "description": "Number of tool calls emitted when the checkpoint fired.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "type": {
          "const": "at_tool_call",
          "type": "string"
        }
      },
      "required": [
        "type",
        "n"
      ],
      "type": "object"
    },
    {
      "description": "Gate was evaluated when a specific event type was observed.",
      "properties": {
        "event_type": {
          "description": "The event type tag that triggered the checkpoint.",
          "type": "string"
        },
        "type": {
          "const": "at_event",
          "type": "string"
        }
      },
      "required": [
        "type",
        "event_type"
      ],
      "type": "object"
    },
    {
      "description": "Gate was evaluated at the end of the session.",
      "properties": {
        "type": {
          "const": "session_end",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    }
  ],
  "title": "SessionPhase"
}
