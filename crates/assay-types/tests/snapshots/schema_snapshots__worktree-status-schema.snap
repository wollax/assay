---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Status of a worktree including runtime state.\n\nExtends worktree information with dirty state, HEAD commit, and ahead/behind counts.",
  "properties": {
    "ahead": {
      "description": "Number of commits ahead of base branch. `None` when the base ref is missing.",
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "base_branch": {
      "description": "The base branch this worktree was created from (from metadata).",
      "type": [
        "string",
        "null"
      ]
    },
    "behind": {
      "description": "Number of commits behind base branch. `None` when the base ref is missing.",
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "branch": {
      "description": "The git branch checked out in this worktree.",
      "type": "string"
    },
    "dirty": {
      "description": "Whether the worktree has uncommitted changes.",
      "type": "boolean"
    },
    "head": {
      "description": "The abbreviated HEAD commit SHA.",
      "type": "string"
    },
    "path": {
      "description": "Absolute path to the worktree directory.",
      "type": "string"
    },
    "spec_slug": {
      "description": "The spec slug this worktree is associated with.",
      "type": "string"
    },
    "warnings": {
      "description": "Warnings about degraded status (e.g., missing base ref).",
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "spec_slug",
    "path",
    "branch",
    "head",
    "dirty"
  ],
  "title": "WorktreeStatus",
  "type": "object"
}
