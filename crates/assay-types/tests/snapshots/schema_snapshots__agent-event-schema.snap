---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A normalized event from an agent session.\n\nProduced by parsing the streaming output of an agent CLI (e.g. Claude's\nNDJSON stream). Non-Claude adapters emit a single synthetic\n[`AgentEvent::SessionStopped`] on exit.",
  "oneOf": [
    {
      "description": "A tool was invoked by the agent.",
      "properties": {
        "input_json": {
          "description": "JSON-encoded tool input parameters.",
          "type": "string"
        },
        "name": {
          "description": "Tool name (e.g. `\"bash\"`, `\"edit\"`, `\"read\"`).",
          "type": "string"
        },
        "type": {
          "const": "tool_called",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "input_json"
      ],
      "type": "object"
    },
    {
      "description": "A tool returned a result to the agent.",
      "properties": {
        "is_error": {
          "description": "Whether the tool invocation resulted in an error.",
          "type": "boolean"
        },
        "name": {
          "description": "Tool name that produced this result.",
          "type": "string"
        },
        "output": {
          "description": "Tool output content (may be truncated by the caller).",
          "type": "string"
        },
        "type": {
          "const": "tool_result",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "output",
        "is_error"
      ],
      "type": "object"
    },
    {
      "description": "A conversation turn boundary.",
      "properties": {
        "turn_index": {
          "description": "Zero-based turn index within the session.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "type": {
          "const": "turn_ended",
          "type": "string"
        }
      },
      "required": [
        "type",
        "turn_index"
      ],
      "type": "object"
    },
    {
      "description": "The agent session has stopped.",
      "properties": {
        "cost_usd": {
          "description": "Total API cost in USD, if reported by the agent.",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "num_turns": {
          "description": "Number of conversation turns completed.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "reason": {
          "description": "Stop reason (e.g. `\"success\"`, `\"error\"`, `\"max_turns\"`).",
          "type": "string"
        },
        "type": {
          "const": "session_stopped",
          "type": "string"
        }
      },
      "required": [
        "type",
        "reason",
        "num_turns"
      ],
      "type": "object"
    },
    {
      "description": "An incremental text chunk from a content block delta.\n\nEmitted per-token during streaming for live display consumers (TUI).\nEach delta carries the content block index so consumers can reconstruct\nper-block text streams.",
      "properties": {
        "block_index": {
          "description": "The content block index this delta belongs to (0-based).",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "text": {
          "description": "The text content of this delta.",
          "type": "string"
        },
        "type": {
          "const": "text_delta",
          "type": "string"
        }
      },
      "required": [
        "type",
        "text",
        "block_index"
      ],
      "type": "object"
    },
    {
      "description": "A complete text content block from an assistant message.\n\nEmitted once per text block for batch consumers (gates, summaries).\nContains the full text of the block — no reconstruction needed.",
      "properties": {
        "text": {
          "description": "The full text content of the block.",
          "type": "string"
        },
        "type": {
          "const": "text_block",
          "type": "string"
        }
      },
      "required": [
        "type",
        "text"
      ],
      "type": "object"
    }
  ],
  "title": "AgentEvent"
}
