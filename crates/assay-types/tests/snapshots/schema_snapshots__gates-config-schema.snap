---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Gate execution configuration.",
  "properties": {
    "agent_eval_mode": {
      "default": "auto",
      "description": "How to handle `AgentReport` criteria: `\"auto\"` (evaluator subprocess)\nor `\"manual\"` (gate_report flow). Defaults to `\"auto\"`.",
      "type": "string"
    },
    "default_timeout": {
      "default": 300,
      "description": "Default timeout for gate commands in seconds. Defaults to 300.",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "evaluator_model": {
      "default": "sonnet",
      "description": "Default model for the evaluator subprocess. Defaults to `\"sonnet\"`.",
      "type": "string"
    },
    "evaluator_retries": {
      "default": 1,
      "description": "Maximum retries for transient evaluator subprocess failures. Defaults to 1.",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "evaluator_timeout": {
      "default": 120,
      "description": "Evaluator subprocess timeout in seconds. Defaults to 120.",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "max_history": {
      "description": "Maximum number of run history files to retain per spec.\nWhen set, oldest files beyond this limit are pruned on each save.\nA value of `0` means unlimited (no pruning). Defaults to `None` (no pruning).",
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "working_dir": {
      "description": "Working directory for gate execution.",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "title": "GatesConfig",
  "type": "object"
}
