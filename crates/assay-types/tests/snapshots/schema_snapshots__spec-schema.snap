---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$defs": {
    "Criterion": {
      "additionalProperties": false,
      "description": "A single acceptance criterion attached to a spec.\n\nEach criterion has a name, description, and an optional shell command\nthat can verify it programmatically. When `cmd` is `None`, the criterion\nis evaluated manually (or in future phases, via an agent `prompt` field).",
      "properties": {
        "cmd": {
          "description": "Optional shell command to verify this criterion.\nOmitted from serialized output when `None`.",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "description": "Detailed description of what this criterion checks.",
          "type": "string"
        },
        "name": {
          "description": "Human-readable name for this criterion.",
          "type": "string"
        },
        "path": {
          "description": "Optional file path to check for existence.\nWhen set (and `cmd` is `None`), the criterion evaluates as a `FileExists` gate.",
          "type": [
            "string",
            "null"
          ]
        },
        "timeout": {
          "description": "Optional timeout in seconds for this criterion's command.\nOverrides the global default but is overridden by CLI `--timeout`.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "description"
      ],
      "type": "object"
    },
    "Enforcement": {
      "description": "Enforcement level for a gate criterion.\n\nDetermines whether a criterion failure blocks the gate (required)\nor is informational only (advisory).",
      "oneOf": [
        {
          "const": "required",
          "description": "Failure blocks the gate. This is the default.",
          "type": "string"
        },
        {
          "const": "advisory",
          "description": "Failure is informational; does not block the gate.",
          "type": "string"
        }
      ]
    },
    "GateSection": {
      "additionalProperties": false,
      "description": "Gate-level configuration section.\n\nParsed from `[gate]` in spec TOML files. Provides spec-wide defaults\nthat individual criteria can override.",
      "properties": {
        "enforcement": {
          "$ref": "#/$defs/Enforcement",
          "default": "required",
          "description": "Default enforcement level for all criteria in this spec."
        }
      },
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A specification that defines what should be built and its acceptance criteria.",
  "properties": {
    "criteria": {
      "description": "Acceptance criteria that must be satisfied.",
      "items": {
        "$ref": "#/$defs/Criterion"
      },
      "type": "array"
    },
    "description": {
      "description": "Human-readable description. Defaults to empty string, omitted from\nserialized output when empty.",
      "type": "string"
    },
    "gate": {
      "anyOf": [
        {
          "$ref": "#/$defs/GateSection"
        },
        {
          "type": "null"
        }
      ],
      "description": "Gate configuration section (enforcement defaults)."
    },
    "name": {
      "description": "Display name for this spec (required, must be unique across all specs).",
      "type": "string"
    }
  },
  "required": [
    "name",
    "criteria"
  ],
  "title": "Spec",
  "type": "object"
}
