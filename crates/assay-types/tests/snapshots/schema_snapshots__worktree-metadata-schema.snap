---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Metadata persisted alongside a worktree at `<worktree>/.assay/worktree.json`.",
  "properties": {
    "base_branch": {
      "description": "The base branch this worktree was created from.",
      "type": "string"
    },
    "spec_slug": {
      "description": "The spec slug this worktree is associated with.",
      "type": "string"
    }
  },
  "required": [
    "base_branch",
    "spec_slug"
  ],
  "title": "WorktreeMetadata",
  "type": "object"
}
