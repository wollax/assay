---
source: crates/assay-types/tests/schema_snapshots.rs
expression: schema.to_value()
---
{
  "$defs": {
    "ChunkRef": {
      "additionalProperties": false,
      "description": "A reference to a `GatesSpec` chunk within a milestone, identified by slug and ordering.\n\nEach `ChunkRef` corresponds to a directory-based spec (a \"chunk\") that\ncontributes to the parent milestone. The `order` field controls the\ncanonical sequence for display and progress tracking.",
      "properties": {
        "order": {
          "description": "Position of this chunk in the milestone's ordered sequence (0-based or 1-based is caller's choice).",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "slug": {
          "description": "Slug of the referenced `GatesSpec` (matches the spec directory/file name).",
          "type": "string"
        }
      },
      "required": [
        "slug",
        "order"
      ],
      "type": "object"
    },
    "MilestoneStatus": {
      "description": "Lifecycle status of a milestone.\n\nTransitions follow the canonical path:\n`Draft` → `InProgress` → `Verify` → `Complete`",
      "oneOf": [
        {
          "const": "draft",
          "description": "Milestone is being defined but not yet in active development.",
          "type": "string"
        },
        {
          "const": "in_progress",
          "description": "Development is actively in progress.",
          "type": "string"
        },
        {
          "const": "verify",
          "description": "All chunks pass gates; awaiting human or automated verification.",
          "type": "string"
        },
        {
          "const": "complete",
          "description": "Milestone is fully complete and merged.",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A milestone, tracking a named feature delivery across one or more gate spec chunks.\n\nPersisted to `.assay/milestones/<slug>.toml`. The `slug` field in the file\nmust match the filename (e.g. `my-feature.toml` → `slug = \"my-feature\"`).",
  "properties": {
    "chunks": {
      "description": "Ordered list of chunk references included in this milestone.",
      "items": {
        "$ref": "#/$defs/ChunkRef"
      },
      "type": "array"
    },
    "completed_chunks": {
      "description": "Slugs of chunks that have been verified and advanced past in the development cycle.\n\nThis is the central state for the cycle state machine: the \"active chunk\" is\nderived at runtime as the lowest-`order` `ChunkRef` whose slug is not in this list.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "created_at": {
      "description": "When this milestone record was first created.",
      "format": "date-time",
      "type": "string"
    },
    "depends_on": {
      "description": "Milestone slugs that must be `Complete` before this one can start.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "description": {
      "description": "Optional longer description of the milestone.",
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "description": "Human-readable display name.",
      "type": "string"
    },
    "pr_base": {
      "description": "Target base branch for the pull request (e.g. `\"main\"`).",
      "type": [
        "string",
        "null"
      ]
    },
    "pr_body_template": {
      "description": "Template for the PR body with placeholder substitution.\n\nSupported placeholders: `{milestone_name}`, `{milestone_slug}`,\n`{chunk_list}` (bulleted chunk names), `{gate_summary}` (pass/fail per chunk).",
      "type": [
        "string",
        "null"
      ]
    },
    "pr_branch": {
      "description": "Feature branch name for this milestone's pull request (e.g. `\"feat/my-feature\"`).",
      "type": [
        "string",
        "null"
      ]
    },
    "pr_labels": {
      "description": "Labels to apply to the GitHub pull request (e.g. `[\"ready-for-review\", \"feature\"]`).",
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "pr_number": {
      "description": "GitHub pull request number, set after successful PR creation.",
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "pr_reviewers": {
      "description": "GitHub usernames to request as reviewers on the pull request.",
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "pr_url": {
      "description": "GitHub pull request URL, set after successful PR creation.",
      "type": [
        "string",
        "null"
      ]
    },
    "slug": {
      "description": "Unique identifier for this milestone; must match the TOML filename without extension.",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/MilestoneStatus",
      "default": "draft",
      "description": "Current lifecycle status. Defaults to `Draft`."
    },
    "updated_at": {
      "description": "When this milestone record was last updated.",
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "slug",
    "name",
    "created_at",
    "updated_at"
  ],
  "title": "Milestone",
  "type": "object"
}
