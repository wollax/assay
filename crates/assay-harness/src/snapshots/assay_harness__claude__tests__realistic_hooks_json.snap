---
source: crates/assay-harness/src/claude.rs
expression: config.hooks_json
---
{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash scripts/post-tool-log.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash scripts/pre-tool-check.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash scripts/on-stop.sh",
            "timeout": 120,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
